{
  "entities": {
    "outfit_sessions": {
      "title": "Outfit Session",
      "description": "User trip planning session",
      "type": "object",
      "properties": {
        "destination": { "type": "string" },
        "budget": { "type": "number" },
        "duration": { "type": "string" },
        "category": { "type": "string" },
        "vibe": { "type": "array", "items": { "type": "string" } },
        "season": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["destination", "userId", "createdAt"]
    },
    "outfit_results": {
      "title": "Outfit Result",
      "description": "AI generated outfit",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "outfit_name": { "type": "string" },
        "styling_breakdown": { "type": "string" },
        "brand_suggestions": { "type": "string" },
        "price_range": { "type": "string" },
        "color_palette": { "type": "array", "items": { "type": "string" } },
        "style_note": { "type": "string" },
        "aesthetic_description": { "type": "string" }
      },
      "required": ["sessionId", "outfit_name"]
    }
  },
  "firestore": {
    "/outfit_sessions/{sessionId}": {
      "schema": "outfit_sessions",
      "description": "Collection of trip planning sessions"
    },
    "/outfit_sessions/{sessionId}/results/{resultId}": {
      "schema": "outfit_results",
      "description": "Subcollection of generated outfits for a session"
    },
    "style_collections": {
      "title": "Style Collection",
      "description": "User-curated boards for specific themes",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "wishlist_items": {
      "title": "Wishlist Item",
      "description": "Saved individual fashion items",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "platform": { "type": "string" },
        "url": { "type": "string" },
        "price": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "journal_entries": {
      "title": "Style Journal Entry",
      "description": "User's personal fashion diary entries",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "mood": { "type": "string" },
        "aiNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt"]
    }
  },
  "firestore": {
    "/outfit_sessions/{sessionId}": {
      "schema": "outfit_sessions",
      "description": "Historical styling sessions"
    },
    "/outfit_sessions/{sessionId}/results/{resultId}": {
      "schema": "outfit_results",
      "description": "Subcollection of generated outfits for a session"
    },
    "/style_collections/{collectionId}": {
      "schema": "style_collections",
      "description": "User boards"
    },
    "/wishlist_items/{itemId}": {
      "schema": "wishlist_items",
      "description": "Saved items"
    },
    "/journal_entries/{entryId}": {
      "schema": "journal_entries",
      "description": "Personal fashion diary"
    }
  }
}
