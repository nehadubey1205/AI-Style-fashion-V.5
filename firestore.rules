rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['destination', 'budget', 'duration', 'occasion', 'aesthetic', 'season', 'createdAt', 'userId'])
        && data.keys().size() == 8
        && data.destination is string && data.destination.size() <= 200
        && data.budget is number && data.budget >= 0
        && data.duration is string && data.duration.size() <= 100
        && data.occasion is string && data.occasion.size() <= 100
        && data.aesthetic is list && data.aesthetic.size() <= 10
        && data.season is string && data.season.size() <= 50
        && data.createdAt == request.time
        && data.userId == request.auth.uid;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['sessionId', 'outfit_name', 'aesthetic_description'])
        && data.keys().size() >= 3
        && data.sessionId is string && isValidId(data.sessionId)
        && data.outfit_name is string && data.outfit_name.size() <= 200
        && data.aesthetic_description is string && data.aesthetic_description.size() <= 500;
    }

    function isValidCollection(data) {
      return data.keys().hasAll(['userId', 'name', 'createdAt'])
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidWishlist(data) {
      return data.keys().hasAll(['userId', 'name', 'createdAt'])
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidJournal(data) {
      return data.keys().hasAll(['userId', 'createdAt'])
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    match /outfit_sessions/{sessionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(sessionId) && isValidSession(incoming());
      allow delete: if isOwner(existing().userId);
    }

    match /outfit_sessions/{sessionId}/results/{resultId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /style_collections/{id} {
      allow read: if isSignedIn() && (resource.data.isPrivate == false || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidCollection(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /wishlist_items/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidWishlist(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /journal_entries/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidJournal(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
